#include <iostream>
#include <vector>
#include <cctype>
#include <cstring>
#include <string>

const int s = 16;

struct Node {
    std::vector<int> ChildNodes;
    std::vector<std::string> ChildWords;
    int fail;
    std::vector<int> lists;

    Node():fail(0){}
};

std::vector<Node> trie;
std::vector<int> pattlens;

void CleanString(std::string& s) {
    while(!s.empty() && (s.back() == '\r' || s.back() == '\n')) {
        s.pop_back();
    }
}

std::vector<std::string> SplitAndLower(const std::string& s) {
    std::vector<std::string> words;
    size_t i = 0;
    while(i<s.size()){
        while(i<s.size() && std::isspace((unsigned char)s[i])){
            ++i;
        }
        if(i>=s.size()) {
            break;
        }
        std::string word;
        while(i<s.size() && !std::isspace((unsigned char)s[i])){
            word.push_back((char)std::tolower((unsigned char)s[i]));
            i++;
        }
        if(!word.empty()){
            words.push_back(word);
        }
    }
    return words;
}

int FindChildNode(int i, const std::string& word){
    const Node& n = trie[i];
    for(size_t j=0; j<n.ChildWords.size(); ++j) {
        if(n.ChildWords[j] == word) {
            return n.ChildNodes[j];
        }
    }
    return -1;
}

void AddPatternWords(std::vector<std::string>& words, int idx) {
    int cur = 0;
    for(size_t i=0; i < words.size(); i++) {
        int c = FindChildNode(cur, words[i]);
        if (c == -1) {
            trie.push_back(Node());
            c = (int)trie.size() - 1;
            trie[cur].ChildNodes.push_back(c);
            trie[cur].ChildWords.push_back(words[i]);
        }
        cur = c;
    }
    trie[cur].lists.push_back(idx);
}

void MakeFails() {
    std::vector<int> q;
    q.push_back(0);
    trie[0].fail = 0;
    size_t head = 0;

    while(head<q.size()) {
        int c = q[head++];

        for(size_t i=0; i < trie[c].ChildWords.size(); i++) {
            std::string w = trie[c].ChildWords[i];
            int v = trie[c].ChildNodes[i];
            if(c == 0) {
                trie[v].fail = 0;
            }else{
                int f = trie[c].fail;

                while(f != 0 && FindChildNode(f, w) == -1) {
                    f = trie[f].fail;
                }
                int nxt = FindChildNode(f, w);
                if(nxt != -1 && nxt != v) {
                    trie[v].fail = nxt;
                }else{
                    trie[v].fail = 0;
                }
            }
            q.push_back(v);
        }
    }
}

int main() {
    trie.push_back(Node());

    std::vector<std::vector<std::string>> Patterns;
    std::string line;

    while(std::getline(std::cin, line)) {
        CleanString(line);
        if(line.empty()) {
            break;
        }
        std::vector<std::string> words = SplitAndLower(line);
        if(words.empty()) {
            break;
        }
        bool isDuplicate = false;
        for(const auto& existing : Patterns) {
            if(existing == words) {
                isDuplicate = true;
                break;
            }
        }
        
        if(!isDuplicate) {
            Patterns.push_back(words);
        }
    }

    pattlens.resize(Patterns.size());
    for(size_t i=0; i < Patterns.size(); i++) {
        pattlens[i] = (int)Patterns[i].size();
        AddPatternWords(Patterns[i], (int)i);
    }

    MakeFails();

    std::vector<std::string> allWords;
    std::vector<int> wordLineNum;
    std::vector<int> wordPosInLine;

    int LineNum = 0;
    while(std::getline(std::cin, line)){
        CleanString(line);
        LineNum++;
        std::vector<std::string> words = SplitAndLower(line);
        for (size_t i = 0; i < words.size(); i++) {
            allWords.push_back(words[i]);
            wordLineNum.push_back(LineNum);
            wordPosInLine.push_back(i + 1);
        }
    }
    
    int cur = 0;
    for(size_t i = 0; i < allWords.size(); i++) {
        const std::string& w = allWords[i];
        
        while(cur != 0 && FindChildNode(cur, w) == -1) {
            cur = trie[cur].fail;
        }
        
        int nxt = FindChildNode(cur, w);
        if(nxt != -1) {
            cur = nxt;
        }
        
        int tmp = cur;
        while(tmp != 0) {
            for(size_t j = 0; j < trie[tmp].lists.size(); j++) {
                int k = trie[tmp].lists[j];
                int startIdx = (int)i - pattlens[k] + 1;
                
                std::cout << wordLineNum[startIdx] << ", " 
                          << wordPosInLine[startIdx] << ", " 
                          << (k + 1) << "\n";
            }
            tmp = trie[tmp].fail;
        }
    }
    
    return 0;
}
