#include <iostream>
#include <cstring>
#include <cctype>
#include <cstdio>

const int max_entries_len = 1000000; 
const int max_value_length = 2200;
const int max_ccn_len = 16;

struct KeyDigits {  //ccn
    char* line;
    char country[max_ccn_len];
    char city[max_ccn_len];
    char number[max_ccn_len];
};

KeyDigits arr[max_entries_len];
KeyDigits temp[max_entries_len];
int n = 0;

int length(const char a[]) {
    int i = 0;
    while (a[i] != '\0') i++;
    return i;
}

void addZeros(char a[], int needLen) {
    int now = length(a);
    int dif = needLen - now;
    if (dif <= 0) return;
    for (int i = now; i >= 0; i--) {
        a[i + dif] = a[i];
    }
    for (int i = 0; i < dif; i++) {
        a[i] = '0';
    }
}

void SortCountry(int pos) {
    int count[10] = {0};
    for (int i = 0; i < n; i++) {
        count[arr[i].country[pos] - '0']++;
    }
    for (int i = 1; i < 10; i++) {
        count[i] += count[i - 1];
    }
    for (int i = n - 1; i >= 0; i--) {
        int digit = arr[i].country[pos] - '0';
        temp[count[digit] - 1] = arr[i];
        count[digit]--;
    }
    for (int i = 0; i < n; i++) {
        arr[i] = temp[i];
    }
}

void SortCity(int pos) {
    int count[10] = {0};
    for (int i = 0; i < n; i++) {
        count[arr[i].city[pos] - '0']++;
    }
    for (int i = 1; i < 10; i++) {
        count[i] += count[i - 1];
    }
    for (int i = n - 1; i >= 0; i--) {
        int digit = arr[i].city[pos] - '0';
        temp[count[digit] - 1] = arr[i];
        count[digit]--;
    }
    for (int i = 0; i < n; i++) {
        arr[i] = temp[i];
    }
}

void SortNumber(int pos) {
    int count[10] = {0};
    for (int i = 0; i < n; i++) {
        count[arr[i].number[pos] - '0']++;
    }
    for (int i = 1; i < 10; i++) {
        count[i] += count[i - 1];
    }
    for (int i = n - 1; i >= 0; i--) {
        int digit = arr[i].number[pos] - '0';
        temp[count[digit] - 1] = arr[i];
        count[digit]--;
    }
    for (int i = 0; i < n; i++) {
        arr[i] = temp[i];
    }
}



void ParsePhoneNumber(const char* line, KeyDigits &d) {
    int i=0;
    int j=0;
    if(line == nullptr || line[0] == '\0') {
        return;
    }
    if(line[i] == '+') {
        i++;
    }
    while(line[i] >= '0' && line[i] <= '9') {
        d.country[j++] = line[i++];
    }
    d.country[j] = '\0';
    while (line[i] == '-' || line[i] == ' ') {
        i++;
    }

    j = 0;
     while (line[i] >= '0' && line[i] <= '9') {
        d.city[j++] = line[i++];
    }
    d.city[j] = '\0';
    while (line[i] == '-' || line[i] == ' ') i++;

    j = 0;
    while (line[i] != '\0' && line[i] != '\t') {
        if (line[i] >= '0' && line[i] <= '9') {
            d.number[j++] = line[i];
        }
        i++;
    }
    d.number[j] = '\0';
}
    
   
int main() {
    char val[max_value_length];
    while(n < max_entries_len && std::cin.getline(val, max_value_length)) {
        int vallen = length(val);
        if (vallen > 0 && val[vallen-1] == '\r') {
            val[vallen - 1] = '\0';
            vallen--;
        }
        if (val[0] == '\0') {
            continue;
        }
        arr[n].line = new char[vallen + 1];
        for(int i=0; i<=vallen; i++) {
            arr[n].line[i] = val[i];
        }
        ParsePhoneNumber(arr[n].line, arr[n]);
        n++;
    }
    int maxLen;


    maxLen = 0;
    for (int i = 0; i < n; i++) {
        if (length(arr[i].number) > maxLen) maxLen = length(arr[i].number);
    }
    for (int i = 0; i < n; i++) {
        addZeros(arr[i].number  , maxLen);
    }
    for (int pos = maxLen - 1; pos >= 0; pos--) {
        SortNumber(pos);
    }


    maxLen = 0;
    for (int i = 0; i < n; i++) {
        if (length(arr[i].city) > maxLen) maxLen = length(arr[i].city);
    }
    for (int i = 0; i < n; i++) {
        addZeros(arr[i].city, maxLen);
    }
    for (int pos = maxLen - 1; pos >= 0; pos--) {
        SortCity(pos);
    }


    maxLen = 0;
    for (int i = 0; i < n; i++) {
        if (length(arr[i].country) > maxLen) maxLen = length(arr[i].country);
    }
    for (int i = 0; i < n; i++) {
        addZeros(arr[i].country, maxLen);
    }
    for (int pos = maxLen - 1; pos >= 0; pos--) {
        SortCountry(pos);
    }


    for (int i = 0; i < n; i++) {
        std::cout << arr[i].line << '\n';
    }

    for (int i = 0; i < n; i++) {
        delete[] arr[i].line;
    }
    return 0;
}
